#: admin.py:107
msgid "Page is not “last”, nor can it be converted to an int."
msgstr "ទំព័រមិនមែនជា “last” ហើយក៏មិនអាចបម្លែងទៅជាចំនួនគត់បានទេ។"

#: apps.py:10
msgid "django CMS Link"
msgstr "តំណ django CMS"

#: cms_plugins.py:43 models.py:73
msgid "Link"
msgstr "ឈ្នាប់"

#: cms_plugins.py:66
msgid "Advanced settings"
msgstr "ការកំណត់កម្រិតខ្ពស់"

#: fields.py:154
msgid "Internal link"
msgstr "តំណខាងក្នុង"

#: fields.py:155
msgid "External link/anchor"
msgstr "តំណខាងក្រៅ/យុថ្កា"

#: fields.py:158
msgid "File link"
msgstr "តំណឯកសារ"

#: fields.py:190
msgid "No destination selected. Use the dropdown to select a destination."
msgstr "មិនបានជ្រើសគោលដៅទេ។ ប្រើបញ្ជីទម្លាក់ចុះដើម្បីជ្រើសគោលដៅ។"

#: fields.py:197
msgid "https://example.com or #anchor"
msgstr "https://example.com ឬ #anchor"

#: fields.py:199
#, python-brace-format
msgid ""
"Provide a link to an external URL, including the schema such as {}. "
"Optionally, add an #anchor (including the #) to scroll to."
msgstr "ផ្តល់តំណទៅ URL ខាងក្រៅ រួមទាំងគ្រោងដូចជា {}។ ជាជម្រើស បន្ថែម #anchor (រួមទាំង #) ដើម្បីរំកិលទៅកាន់វា។"

#: fields.py:208
msgid ""
"Select from available internal destinations. Optionally, add an anchor to "
"scroll to."
msgstr "ជ្រើសពីគោលដៅខាងក្នុងដែលមាន។ ជាជម្រើស បន្ថែមយុថ្កាដើម្បីរំកិលទៅកាន់វា។"

#: fields.py:210
msgid "Select internal destination"
msgstr "ជ្រើសគោលដៅខាងក្នុង"

#: fields.py:216
msgid "#anchor"
msgstr "#anchor"

#: fields.py:217
msgid "Provide an anchor to scroll to."
msgstr "ផ្តល់យុថ្កាដើម្បីរំកិលទៅកាន់វា។"

#: fields.py:227
msgid "Select a file as destination."
msgstr "ជ្រើសឯកសារជាគោលដៅ។"

#: fields.py:264
msgid "Select site"
msgstr "ជ្រើសគេហទំព័រ"

#: fields.py:313
msgid "Select a link type and provide a link."
msgstr "ជ្រើសប្រភេទតំណ ហើយផ្តល់តំណ។"

#: models.py:28
msgid "Default"
msgstr "លំនាំដើម"

#: models.py:41
msgid "Open in new window"
msgstr "បើកក្នុងបង្អួចថ្មី"

#: models.py:42
msgid "Open in same window"
msgstr "បើកក្នុងបង្អួចដូចគ្នា"

#: models.py:43
msgid "Delegate to parent"
msgstr "ផ្ទេរទៅមេ"

#: models.py:44
msgid "Delegate to top"
msgstr "ផ្ទេរទៅកំពូល"

#: models.py:61
msgid "Template"
msgstr "ពុម្ព"

#: models.py:67
msgid "Display name"
msgstr "ឈ្មោះបង្ហាញ"

#: models.py:77
msgid "Target"
msgstr "គោលដៅ"

#: models.py:103
msgid "Attributes"
msgstr "គុណលក្ខណៈ"

#: models.py:130
msgid "<link is missing>"
msgstr "<បាត់តំណ>"

#: models.py:139
msgid "Link is required."
msgstr "តំណគឺត្រូវការ។"

#: validators.py:61
msgid "Enter a valid anchor"
msgstr "បញ្ចូលយុថ្កាត្រឹមត្រូវ"

#: validators.py:104
msgid "Enter a valid phone number"
msgstr "បញ្ចូលលេខទូរស័ព្ទត្រឹមត្រូវ"
