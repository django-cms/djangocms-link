#: admin.py:107
msgid "Page is not “last”, nor can it be converted to an int."
msgstr "Az oldal nem “last”, és nem alakítható egész számmá."

#: apps.py:10
msgid "django CMS Link"
msgstr "django CMS hivatkozás"

#: cms_plugins.py:43 models.py:73
msgid "Link"
msgstr "Hivatkozás"

#: cms_plugins.py:66
msgid "Advanced settings"
msgstr "Speciális beállítások"

#: fields.py:154
msgid "Internal link"
msgstr "Belső hivatkozás"

#: fields.py:155
msgid "External link/anchor"
msgstr "Külső hivatkozás/horgony"

#: fields.py:158
msgid "File link"
msgstr "Fájlhivatkozás"

#: fields.py:190
msgid "No destination selected. Use the dropdown to select a destination."
msgstr "Nincs kiválasztva cél. A legördülő menüvel válasszon célt."

#: fields.py:197
msgid "https://example.com or #anchor"
msgstr "https://example.com vagy #horgony"

#: fields.py:199
#, python-brace-format
msgid ""
"Provide a link to an external URL, including the schema such as {}. "
"Optionally, add an #anchor (including the #) to scroll to."
msgstr ""
"Adjon meg egy külső URL-re mutató hivatkozást, a sémával együtt, például: "
"{}. Opcionálisan adjon hozzá egy #horgonyt (a # jellel együtt), amelyhez "
"görgetni kell."

#: fields.py:208
msgid ""
"Select from available internal destinations. Optionally, add an anchor to "
"scroll to."
msgstr ""
"Válasszon az elérhető belső célok közül. Opcionálisan adjon meg egy "
"horgonyt, amelyhez görgetni kell."

#: fields.py:210
msgid "Select internal destination"
msgstr "Belső cél kiválasztása"

#: fields.py:216
msgid "#anchor"
msgstr "#horgony"

#: fields.py:217
msgid "Provide an anchor to scroll to."
msgstr "Adjon meg egy horgonyt, amelyhez görgetni kell."

#: fields.py:227
msgid "Select a file as destination."
msgstr "Válasszon fájlt célként."

#: fields.py:264
msgid "Select site"
msgstr "Webhely kiválasztása"

#: fields.py:313
msgid "Select a link type and provide a link."
msgstr "Válasszon hivatkozástípust, és adjon meg egy hivatkozást."

#: models.py:28
msgid "Default"
msgstr "Alapértelmezett"

#: models.py:41
msgid "Open in new window"
msgstr "Megnyitás új ablakban"

#: models.py:42
msgid "Open in same window"
msgstr "Megnyitás ugyanabban az ablakban"

#: models.py:43
msgid "Delegate to parent"
msgstr "Delegálás a szülőnek"

#: models.py:44
msgid "Delegate to top"
msgstr "Delegálás a legfelsőnek"

#: models.py:61
msgid "Template"
msgstr "Sablon"

#: models.py:67
msgid "Display name"
msgstr "Megjelenített név"

#: models.py:77
msgid "Target"
msgstr "Cél"

#: models.py:103
msgid "Attributes"
msgstr "Attribútumok"

#: models.py:130
msgid "<link is missing>"
msgstr "<hiányzó hivatkozás>"

#: models.py:139
msgid "Link is required."
msgstr "A hivatkozás megadása kötelező."

#: validators.py:61
msgid "Enter a valid anchor"
msgstr "Adjon meg érvényes horgonyt"

#: validators.py:104
msgid "Enter a valid phone number"
msgstr "Adjon meg érvényes telefonszámot"
