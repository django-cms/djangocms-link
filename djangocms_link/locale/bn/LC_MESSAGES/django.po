#: admin.py:107
msgid "Page is not “last”, nor can it be converted to an int."
msgstr "পৃষ্ঠা “last” নয়, এবং এটিকে পূর্ণসংখ্যায় রূপান্তর করা যায় না।"

#: apps.py:10
msgid "django CMS Link"
msgstr "django CMS লিংক"

#: cms_plugins.py:43 models.py:73
msgid "Link"
msgstr "লিংক"

#: cms_plugins.py:66
msgid "Advanced settings"
msgstr "উন্নত সেটিংস"

#: fields.py:154
msgid "Internal link"
msgstr "অভ্যন্তরীণ লিংক"

#: fields.py:155
msgid "External link/anchor"
msgstr "বাহ্যিক লিংক/অ্যাঙ্কর"

#: fields.py:158
msgid "File link"
msgstr "ফাইল লিংক"

#: fields.py:190
msgid "No destination selected. Use the dropdown to select a destination."
msgstr "কোনো গন্তব্য নির্বাচন করা হয়নি। গন্তব্য নির্বাচন করতে ড্রপডাউন ব্যবহার করুন।"

#: fields.py:197
msgid "https://example.com or #anchor"
msgstr "https://example.com অথবা #anchor"

#: fields.py:199
#, python-brace-format
msgid ""
"Provide a link to an external URL, including the schema such as {}. "
"Optionally, add an #anchor (including the #) to scroll to."
msgstr "বাহ্যিক URL-এ একটি লিংক দিন, {}-এর মতো স্কিমসহ। ঐচ্ছিকভাবে স্ক্রল করার জন্য #anchor (#-সহ) যোগ করুন।"

#: fields.py:208
msgid ""
"Select from available internal destinations. Optionally, add an anchor to "
"scroll to."
msgstr "উপলব্ধ অভ্যন্তরীণ গন্তব্য থেকে নির্বাচন করুন। ঐচ্ছিকভাবে স্ক্রল করার জন্য একটি অ্যাঙ্কর যোগ করুন।"

#: fields.py:210
msgid "Select internal destination"
msgstr "অভ্যন্তরীণ গন্তব্য নির্বাচন করুন"

#: fields.py:216
msgid "#anchor"
msgstr "#anchor"

#: fields.py:217
msgid "Provide an anchor to scroll to."
msgstr "স্ক্রল করার জন্য একটি অ্যাঙ্কর দিন।"

#: fields.py:227
msgid "Select a file as destination."
msgstr "গন্তব্য হিসেবে একটি ফাইল নির্বাচন করুন।"

#: fields.py:264
msgid "Select site"
msgstr "সাইট নির্বাচন করুন"

#: fields.py:313
msgid "Select a link type and provide a link."
msgstr "একটি লিংকের ধরন নির্বাচন করুন এবং লিংক দিন।"

