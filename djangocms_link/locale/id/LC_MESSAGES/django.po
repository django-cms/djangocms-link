msgid "No destination selected. Use the dropdown to select a destination."
msgstr "Tidak ada tujuan yang dipilih. Gunakan dropdown untuk memilih tujuan."

#: fields.py:197
msgid "https://example.com or #anchor"
msgstr "https://example.com atau #anchor"

#: fields.py:199
#, python-brace-format
msgid ""
"Provide a link to an external URL, including the schema such as {}. "
"Optionally, add an #anchor (including the #) to scroll to."
msgstr "Berikan tautan ke URL eksternal, termasuk skema seperti {}. Secara opsional, tambahkan #anchor (termasuk #) untuk digulirkan ke sana."

#: fields.py:208
msgid ""
"Select from available internal destinations. Optionally, add an anchor to "
"scroll to."
msgstr "Pilih dari tujuan internal yang tersedia. Secara opsional, tambahkan jangkar untuk digulirkan ke sana."

#: fields.py:210
msgid "Select internal destination"
msgstr "Pilih tujuan internal"

#: fields.py:216
msgid "#anchor"
msgstr "#anchor"

#: fields.py:217
msgid "Provide an anchor to scroll to."
msgstr "Berikan jangkar untuk digulirkan ke sana."

#: fields.py:227
msgid "Select a file as destination."
msgstr "Pilih berkas sebagai tujuan."

#: fields.py:264
msgid "Select site"
msgstr "Pilih situs"

#: fields.py:313
msgid "Select a link type and provide a link."
msgstr "Pilih jenis tautan dan berikan tautan."

