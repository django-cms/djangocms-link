#: fields.py:175
msgid "https://example.com or #anchor"
msgstr "https://example.com ياكى #anchor"

#: fields.py:177
msgid ""
"Provide a link to an external URL, including the schema such as 'https://', "
"'tel:', or 'mailto:'. Optionally, add an #anchor (including the #) to scroll"
" to."
msgstr "تاشقى URL غا ئۇلانما كىرگۈزۈڭ، 'https://'، 'tel:' ياكى 'mailto:' قاتارلىق لايىھەنىمۇ ئۆز ئىچىگە ئالسۇن. ئىختىيارىي ھالدا سىيرىلىدىغان #anchor (# بىلەن) قوشۇڭ."

#: fields.py:186
msgid ""
"Select from available internal destinations. Optionally, add an anchor to "
"scroll to."
msgstr "بار بولغان ئىچكى نىشانلاردىن تاللاڭ. ئىختىيارىي ھالدا سىيرىلىدىغان لەڭگەر قوشۇڭ."

#: fields.py:188
msgid "Select internal destination"
msgstr "ئىچكى نىشاننى تاللاڭ"

#: fields.py:194
msgid "#anchor"
msgstr "#anchor"

#: fields.py:195
msgid "Provide an anchor to scroll to."
msgstr "سىيرىلىدىغان لەڭگەرنى كىرگۈزۈڭ."

#: fields.py:206
msgid "Select a file as destination."
msgstr "نىشان سۈپىتىدە ھۆججەت تاللاڭ."

#: fields.py:215
msgid "Select site"
msgstr "تور بېكەتنى تاللاڭ"

#: fields.py:249
msgid "Select a link type and provide a link."
msgstr "ئۇلانما تۈرىنى تاللاپ ئۇلانما كىرگۈزۈڭ."

