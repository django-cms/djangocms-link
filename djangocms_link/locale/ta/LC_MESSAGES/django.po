#: admin.py:107
msgid "Page is not “last”, nor can it be converted to an int."
msgstr "பக்கம் “last” அல்ல, மேலும் அதை முழு எண்ணாக மாற்ற முடியாது."

#: apps.py:10
msgid "django CMS Link"
msgstr "django CMS இணைப்பு"

#: cms_plugins.py:43 models.py:73
msgid "Link"
msgstr "தொடுப்பு"

#: cms_plugins.py:66
msgid "Advanced settings"
msgstr "மேம்பட்ட அமைப்புகள்"

#: fields.py:154
msgid "Internal link"
msgstr "உள் இணைப்பு"

#: fields.py:155
msgid "External link/anchor"
msgstr "வெளி இணைப்பு/நங்கூரம்"

#: fields.py:158
msgid "File link"
msgstr "கோப்பு இணைப்பு"

#: fields.py:190
msgid "No destination selected. Use the dropdown to select a destination."
msgstr "இலக்கு எதுவும் தேர்ந்தெடுக்கப்படவில்லை. இலக்கைத் தேர்வுசெய்ய கீழ்தோன்றலைப் பயன்படுத்தவும்."

#: fields.py:197
msgid "https://example.com or #anchor"
msgstr "https://example.com அல்லது #anchor"

#: fields.py:199
#, python-brace-format
msgid ""
"Provide a link to an external URL, including the schema such as {}. "
"Optionally, add an #anchor (including the #) to scroll to."
msgstr "வெளி URL-க்கு இணைப்பை வழங்கவும், {} போன்ற திட்டத்தையும் சேர்த்து. விருப்பமாக, உருட்டிச் செல்ல #anchor (# உட்பட) சேர்க்கவும்."

#: fields.py:208
msgid ""
"Select from available internal destinations. Optionally, add an anchor to "
"scroll to."
msgstr "கிடைக்கும் உள் இலக்குகளில் இருந்து தேர்ந்தெடுக்கவும். விருப்பமாக, உருட்டிச் செல்ல ஒரு நங்கூரத்தைச் சேர்க்கவும்."

#: fields.py:210
msgid "Select internal destination"
msgstr "உள் இலக்கைத் தேர்ந்தெடுக்கவும்"

#: fields.py:216
msgid "#anchor"
msgstr "#anchor"

#: fields.py:217
msgid "Provide an anchor to scroll to."
msgstr "உருட்டிச் செல்ல ஒரு நங்கூரத்தை வழங்கவும்."

#: fields.py:227
msgid "Select a file as destination."
msgstr "இலக்காக ஒரு கோப்பைத் தேர்ந்தெடுக்கவும்."

#: fields.py:264
msgid "Select site"
msgstr "தளத்தைத் தேர்ந்தெடுக்கவும்"

#: fields.py:313
msgid "Select a link type and provide a link."
msgstr "இணைப்பு வகையைத் தேர்ந்தெடுத்து இணைப்பை வழங்கவும்."

#: models.py:28
msgid "Default"
msgstr "இயல்புநிலை"

