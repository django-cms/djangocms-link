msgstr "பெற்றோருக்கு ஒப்படை"

#: models.py:44
msgid "Delegate to top"
msgstr "மேல்மட்டத்துக்கு ஒப்படை"

#: models.py:61
msgid "Template"
msgstr "வார்ப்புரு"

#: models.py:67
msgid "Display name"
msgstr "காட்டும் பெயர்"

#: models.py:77
msgid "Target"
msgstr "இலக்கு"

#: models.py:103
msgid "Attributes"
msgstr "பண்புக்கூறுகள்"

#: models.py:130
msgid "<link is missing>"
msgstr "<இணைப்பு இல்லை>"

#: models.py:139
msgid "Link is required."
msgstr "இணைப்பு அவசியம்."

#: validators.py:61
