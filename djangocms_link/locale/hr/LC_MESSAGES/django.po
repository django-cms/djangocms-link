msgstr "Otvori u istom prozoru"

#: models.py:43
msgid "Delegate to parent"
msgstr "Delegiraj roditelju"

#: models.py:44
msgid "Delegate to top"
msgstr "Delegiraj na vrh"

#: models.py:61
msgid "Template"
msgstr "Predložak"

#: models.py:67
msgid "Display name"
msgstr "Naziv za prikaz"

#: models.py:77
msgid "Target"
msgstr "Odredište"

#: models.py:103
msgid "Attributes"
msgstr "Atributi"

