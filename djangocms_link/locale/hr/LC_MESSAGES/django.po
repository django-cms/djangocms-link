#: admin.py:107
msgid "Page is not “last”, nor can it be converted to an int."
msgstr "Stranica nije “last” niti se može pretvoriti u cijeli broj."

#: apps.py:10
msgid "django CMS Link"
msgstr "django CMS poveznica"

#: cms_plugins.py:43 models.py:73
msgid "Link"
msgstr "Poveznica"

#: cms_plugins.py:66
msgid "Advanced settings"
msgstr "Napredne postavke"

#: fields.py:154
msgid "Internal link"
msgstr "Interna poveznica"

#: fields.py:155
msgid "External link/anchor"
msgstr "Vanjska poveznica/sidro"

#: fields.py:158
msgid "File link"
msgstr "Poveznica na datoteku"

#: fields.py:190
msgid "No destination selected. Use the dropdown to select a destination."
msgstr "Nije odabrano odredište. Upotrijebite padajući izbornik za odabir odredišta."

#: fields.py:197
msgid "https://example.com or #anchor"
msgstr "https://example.com ili #sidro"

#: fields.py:199
#, python-brace-format
msgid ""
"Provide a link to an external URL, including the schema such as {}. "
"Optionally, add an #anchor (including the #) to scroll to."
msgstr "Unesite poveznicu na vanjski URL, uključujući shemu kao što je {}. Po želji dodajte #sidro (uključujući #) na koje se treba pomaknuti."

#: fields.py:208
msgid ""
"Select from available internal destinations. Optionally, add an anchor to "
"scroll to."
msgstr "Odaberite među dostupnim internim odredištima. Po želji dodajte sidro na koje se treba pomaknuti."

#: fields.py:210
msgid "Select internal destination"
msgstr "Odaberi interno odredište"

#: fields.py:216
msgid "#anchor"
msgstr "#sidro"

#: fields.py:217
msgid "Provide an anchor to scroll to."
msgstr "Unesite sidro na koje se treba pomaknuti."

#: fields.py:227
msgid "Select a file as destination."
msgstr "Odaberite datoteku kao odredište."

#: fields.py:264
msgid "Select site"
msgstr "Odaberi web-mjesto"

#: fields.py:313
msgid "Select a link type and provide a link."
msgstr "Odaberite vrstu poveznice i unesite poveznicu."

#: models.py:28
msgid "Default"
msgstr "Zadano"

#: models.py:41
