#: admin.py:107
msgid "Page is not “last”, nor can it be converted to an int."
msgstr "La pàgina no és “last” ni es pot convertir en un enter."

#: apps.py:10
msgid "django CMS Link"
msgstr "Enllaç de django CMS"

#: cms_plugins.py:43 models.py:73
msgid "Link"
msgstr "Enllaç"

#: cms_plugins.py:66
msgid "Advanced settings"
msgstr "Configuració avançada"

#: fields.py:154
msgid "Internal link"
msgstr "Enllaç intern"

#: fields.py:155
msgid "External link/anchor"
msgstr "Enllaç extern/àncora"

#: fields.py:158
msgid "File link"
msgstr "Enllaç de fitxer"

#: fields.py:190
msgid "No destination selected. Use the dropdown to select a destination."
msgstr "No s’ha seleccionat cap destinació. Feu servir el desplegable per seleccionar-ne una."

#: fields.py:197
msgid "https://example.com or #anchor"
msgstr "https://example.com o #ancora"

#: fields.py:199
#, python-brace-format
msgid ""
"Provide a link to an external URL, including the schema such as {}. "
"Optionally, add an #anchor (including the #) to scroll to."
msgstr "Proporcioneu un enllaç a un URL extern, inclòs l’esquema com ara {}. Opcionalment, afegiu una #ancora (incloent-hi el #) on desplaçar-se."

#: fields.py:208
msgid ""
"Select from available internal destinations. Optionally, add an anchor to "
"scroll to."
msgstr "Seleccioneu entre les destinacions internes disponibles. Opcionalment, afegiu una àncora on desplaçar-se."

#: fields.py:210
msgid "Select internal destination"
msgstr "Seleccioneu una destinació interna"

#: fields.py:216
msgid "#anchor"
msgstr "#ancora"

#: fields.py:217
msgid "Provide an anchor to scroll to."
msgstr "Proporcioneu una àncora on desplaçar-se."

#: fields.py:227
msgid "Select a file as destination."
msgstr "Seleccioneu un fitxer com a destinació."

#: fields.py:264
msgid "Select site"
msgstr "Seleccioneu el lloc"

#: fields.py:313
msgid "Select a link type and provide a link."
msgstr "Seleccioneu un tipus d’enllaç i proporcioneu un enllaç."

#: models.py:28
msgid "Default"
msgstr "Per defecte"

#: models.py:41
msgid "Open in new window"
msgstr "Obre en una finestra nova"

#: models.py:42
msgid "Open in same window"
msgstr "Obre a la mateixa finestra"

#: models.py:43
msgid "Delegate to parent"
msgstr "Delega al pare"

#: models.py:44
msgid "Delegate to top"
msgstr "Delega al nivell superior"

#: models.py:61
msgid "Template"
msgstr "Plantilla"

#: models.py:67
msgid "Display name"
msgstr "Nom visible"

#: models.py:77
msgid "Target"
msgstr "Destinació"

#: models.py:103
msgid "Attributes"
msgstr "Atributs"

#: models.py:130
msgid "<link is missing>"
msgstr "<falta l’enllaç>"

#: models.py:139
msgid "Link is required."
msgstr "L’enllaç és obligatori."

#: validators.py:61
msgid "Enter a valid anchor"
msgstr "Introduïu una àncora vàlida"

