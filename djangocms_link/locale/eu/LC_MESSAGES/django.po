#: admin.py:107
msgid "Page is not “last”, nor can it be converted to an int."
msgstr "Orria ez da “last”, eta ezin da zenbaki oso bihurtu."

#: apps.py:10
msgid "django CMS Link"
msgstr "django CMS esteka"

#: cms_plugins.py:43 models.py:73
msgid "Link"
msgstr "Esteka"

#: cms_plugins.py:66
msgid "Advanced settings"
msgstr "Ezarpen aurreratuak"

#: fields.py:154
msgid "Internal link"
msgstr "Barne esteka"

#: fields.py:155
msgid "External link/anchor"
msgstr "Kanpoko esteka/aingura"

#: fields.py:158
msgid "File link"
msgstr "Fitxategi-esteka"

#: fields.py:190
msgid "No destination selected. Use the dropdown to select a destination."
msgstr "Ez da helbururik hautatu. Erabili goitibeherakoa helburu bat hautatzeko."

#: fields.py:197
msgid "https://example.com or #anchor"
msgstr "https://example.com edo #aingura"

#: fields.py:199
#, python-brace-format
msgid ""
"Provide a link to an external URL, including the schema such as {}. "
"Optionally, add an #anchor (including the #) to scroll to."
msgstr "Eman kanpoko URL baterako esteka, {} bezalako eskema barne. Aukeran, gehitu #aingura (# barne) hara korritzeko."

#: fields.py:208
msgid ""
"Select from available internal destinations. Optionally, add an anchor to "
"scroll to."
msgstr "Hautatu erabilgarri dauden barne-helburuen artean. Aukeran, gehitu aingura bat hara korritzeko."

#: fields.py:210
msgid "Select internal destination"
msgstr "Hautatu barne helburua"

#: fields.py:216
msgid "#anchor"
msgstr "#aingura"

#: fields.py:217
msgid "Provide an anchor to scroll to."
msgstr "Eman korritzeko aingura bat."

#: fields.py:227
msgid "Select a file as destination."
msgstr "Hautatu fitxategi bat helburu gisa."

#: fields.py:264
msgid "Select site"
msgstr "Hautatu gunea"

#: fields.py:313
msgid "Select a link type and provide a link."
msgstr "Hautatu esteka mota bat eta eman esteka bat."

#: models.py:28
msgid "Default"
msgstr "Lehenetsia"

#: models.py:41
msgid "Open in new window"
msgstr "Ireki leiho berrian"

#: models.py:42
msgid "Open in same window"
msgstr "Ireki leiho berean"

#: models.py:43
msgid "Delegate to parent"
msgstr "Delegatu gurasora"

#: models.py:44
msgid "Delegate to top"
msgstr "Delegatu goikora"

#: models.py:61
msgid "Template"
msgstr "Txantiloia"

#: models.py:67
msgid "Display name"
msgstr "Bistaratzeko izena"

#: models.py:77
msgid "Target"
msgstr "Helburua"

#: models.py:103
msgid "Attributes"
msgstr "Atributuak"

#: models.py:130
msgid "<link is missing>"
msgstr "<esteka falta da>"

#: models.py:139
msgid "Link is required."
msgstr "Esteka beharrezkoa da."

#: validators.py:61
msgid "Enter a valid anchor"
msgstr "Sartu baliozko aingura bat"

#: validators.py:104
msgid "Enter a valid phone number"
msgstr "Sartu baliozko telefono-zenbaki bat"
