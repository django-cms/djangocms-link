#: admin.py:107
msgid "Page is not “last”, nor can it be converted to an int."
msgstr "Faqja nuk është “last” dhe nuk mund të konvertohet në numër të plotë."

#: apps.py:10
msgid "django CMS Link"
msgstr "Lidhje django CMS"

#: cms_plugins.py:43 models.py:73
msgid "Link"
msgstr "Lidhje"

#: cms_plugins.py:66
msgid "Advanced settings"
msgstr "Rregullime të mëtejshme"

#: fields.py:154
msgid "Internal link"
msgstr "Lidhje e brendshme"

#: fields.py:155
msgid "External link/anchor"
msgstr "Lidhje e jashtme/ankorë"

#: fields.py:158
msgid "File link"
msgstr "Lidhje kartele"

#: fields.py:190
msgid "No destination selected. Use the dropdown to select a destination."
msgstr "Nuk është zgjedhur destinacion. Përdorni menynë zbritëse për të zgjedhur një destinacion."

#: fields.py:197
msgid "https://example.com or #anchor"
msgstr "https://example.com ose #ankorë"

#: fields.py:199
#, python-brace-format
msgid ""
"Provide a link to an external URL, including the schema such as {}. "
"Optionally, add an #anchor (including the #) to scroll to."
msgstr "Jepni një lidhje për një URL të jashtme, duke përfshirë skemën si {}. Opsionalisht, shtoni një #ankorë (përfshirë #) ku të lëvizet."

#: fields.py:208
msgid ""
"Select from available internal destinations. Optionally, add an anchor to "
"scroll to."
msgstr "Zgjidhni nga destinacionet e brendshme të disponueshme. Opsionalisht, shtoni një ankorë ku të lëvizet."

#: fields.py:210
msgid "Select internal destination"
msgstr "Zgjidh destinacion të brendshëm"

#: fields.py:216
msgid "#anchor"
msgstr "#ankorë"

#: fields.py:217
msgid "Provide an anchor to scroll to."
msgstr "Jepni një ankorë ku të lëvizet."

#: fields.py:227
msgid "Select a file as destination."
msgstr "Zgjidhni një skedar si destinacion."

#: fields.py:264
msgid "Select site"
msgstr "Zgjidh sitin"

#: fields.py:313
msgid "Select a link type and provide a link."
msgstr "Zgjidhni një lloj lidhjeje dhe jepni një lidhje."

#: models.py:28
msgid "Default"
msgstr "Parazgjedhje"

#: models.py:41
msgid "Open in new window"
msgstr "Hape në dritare të re"

#: models.py:42
msgid "Open in same window"
msgstr "Hape në të njëjtën dritare"

#: models.py:43
msgid "Delegate to parent"
msgstr "Delego te prindi"

#: models.py:44
msgid "Delegate to top"
msgstr "Delego te niveli i sipërm"

#: models.py:61
msgid "Template"
msgstr "Gjedhe"

#: models.py:67
msgid "Display name"
msgstr "Emër në ekran"

#: models.py:77
msgid "Target"
msgstr "Objektiv"

#: models.py:103
msgid "Attributes"
msgstr "Atribute"

#: models.py:130
msgid "<link is missing>"
msgstr "<lidhja mungon>"

#: models.py:139
msgid "Link is required."
msgstr "Lidhja është e detyrueshme."

#: validators.py:61
msgid "Enter a valid anchor"
msgstr "Shkruani një ankorë të vlefshme"

#: validators.py:104
msgid "Enter a valid phone number"
msgstr "Shkruani një numër telefoni të vlefshëm"
