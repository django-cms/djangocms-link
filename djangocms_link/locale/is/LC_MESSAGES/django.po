msgid "Advanced settings"
msgstr "Ítarlegar stillingar"

#: fields.py:154
msgid "Internal link"
msgstr "Innri hlekkur"

#: fields.py:155
msgid "External link/anchor"
msgstr "Ytri hlekkur/akkeri"

#: fields.py:158
msgid "File link"
msgstr "Skráarhlekkur"

#: fields.py:190
msgid "No destination selected. Use the dropdown to select a destination."
msgstr "Enginn áfangastaður valinn. Notaðu fellilistann til að velja áfangastað."

#: fields.py:197
msgid "https://example.com or #anchor"
msgstr "https://example.com eða #akkeri"

#: fields.py:199
#, python-brace-format
msgid ""
"Provide a link to an external URL, including the schema such as {}. "
"Optionally, add an #anchor (including the #) to scroll to."
msgstr "Gefðu upp hlekk á ytri vefslóð, þar á meðal skema eins og {}. Valfrjálst má bæta við #akkeri (með #) til að fletta að."

#: fields.py:208
msgid ""
"Select from available internal destinations. Optionally, add an anchor to "
"scroll to."
msgstr "Veldu úr tiltækum innri áfangastöðum. Valfrjálst má bæta við akkeri til að fletta að."

#: fields.py:210
msgid "Select internal destination"
msgstr "Velja innri áfangastað"

#: fields.py:216
msgid "#anchor"
msgstr "#akkeri"

#: fields.py:217
msgid "Provide an anchor to scroll to."
msgstr "Gefðu upp akkeri til að fletta að."

#: fields.py:227
msgid "Select a file as destination."
msgstr "Veldu skrá sem áfangastað."

#: fields.py:264
msgid "Select site"
msgstr "Veldu vef"

#: fields.py:313
msgid "Select a link type and provide a link."
msgstr "Veldu gerð hlekks og gefðu upp hlekk."

