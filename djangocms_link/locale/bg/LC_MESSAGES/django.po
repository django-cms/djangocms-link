#: admin.py:107
msgid "Page is not “last”, nor can it be converted to an int."
msgstr "Страницата не е “last“ и не може да бъде преобразувана в цяло число."

#: apps.py:10
msgid "django CMS Link"
msgstr "Връзка за django CMS"

#: cms_plugins.py:43 models.py:73
msgid "Link"
msgstr "Връзка"

#: cms_plugins.py:66
msgid "Advanced settings"
msgstr "Разширени настройки"

#: fields.py:154
msgid "Internal link"
msgstr "Вътрешна връзка"

#: fields.py:155
msgid "External link/anchor"
msgstr "Външна връзка/котва"

#: fields.py:158
msgid "File link"
msgstr "Връзка към файл"

#: fields.py:190
msgid "No destination selected. Use the dropdown to select a destination."
msgstr "Не е избрана дестинация. Използвайте падащото меню, за да изберете дестинация."

#: fields.py:197
msgid "https://example.com or #anchor"
msgstr "https://example.com или #котва"

#: fields.py:199
#, python-brace-format
msgid ""
"Provide a link to an external URL, including the schema such as {}. "
"Optionally, add an #anchor (including the #) to scroll to."
msgstr "Въведете връзка към външен URL, включително схемата, например {}. По желание добавете #котва (включително #), към която да се превърти."

#: fields.py:208
msgid ""
"Select from available internal destinations. Optionally, add an anchor to "
"scroll to."
msgstr "Изберете от наличните вътрешни дестинации. По желание добавете котва за превъртане."

#: fields.py:210
msgid "Select internal destination"
msgstr "Изберете вътрешна дестинация"

#: fields.py:216
msgid "#anchor"
msgstr "#котва"

#: fields.py:217
msgid "Provide an anchor to scroll to."
msgstr "Въведете котва за превъртане."

#: fields.py:227
msgid "Select a file as destination."
msgstr "Изберете файл като дестинация."

#: fields.py:264
msgid "Select site"
msgstr "Изберете сайт"

#: fields.py:313
msgid "Select a link type and provide a link."
msgstr "Изберете тип връзка и въведете връзка."

#: models.py:28
msgid "Default"
msgstr "По подразбиране"

#: models.py:41
msgid "Open in new window"
msgstr "Отваряне в нов прозорец"

#: models.py:42
msgid "Open in same window"
msgstr "Отваряне в същия прозорец"

#: models.py:43
msgid "Delegate to parent"
msgstr "Делегиране към родител"

#: models.py:44
msgid "Delegate to top"
msgstr "Делегиране към най-горното ниво"

#: models.py:61
msgid "Template"
msgstr "Шаблон"

#: models.py:67
msgid "Display name"
msgstr "Показвано име"

#: models.py:77
msgid "Target"
msgstr "Цел"

#: models.py:103
msgid "Attributes"
msgstr "Атрибути"

#: models.py:130
msgid "<link is missing>"
msgstr "<липсва връзка>"

#: models.py:139
msgid "Link is required."
msgstr "Връзката е задължителна."

#: validators.py:61
msgid "Enter a valid anchor"
msgstr "Въведете валидна котва"

#: validators.py:104
msgid "Enter a valid phone number"
msgstr "Въведете валиден телефонен номер"
