msgid "External link/anchor"
msgstr "Externý odkaz/kotva"

#: fields.py:158
msgid "File link"
msgstr "Odkaz na súbor"

#: fields.py:190
msgid "No destination selected. Use the dropdown to select a destination."
msgstr "Nebolo vybrané žiadne cieľové miesto. Cieľ vyberte pomocou rozbaľovacej ponuky."

#: fields.py:197
msgid "https://example.com or #anchor"
msgstr "https://example.com alebo #kotva"

#: fields.py:199
#, python-brace-format
msgid ""
"Provide a link to an external URL, including the schema such as {}. "
"Optionally, add an #anchor (including the #) to scroll to."
msgstr "Zadajte odkaz na externú URL vrátane schémy, napríklad {}. Voliteľne pridajte #kotva (vrátane #), ku ktorej sa má posunúť."

#: fields.py:208
msgid ""
"Select from available internal destinations. Optionally, add an anchor to "
"scroll to."
msgstr "Vyberte z dostupných interných cieľov. Voliteľne pridajte kotvu, ku ktorej sa má posunúť."

#: fields.py:210
msgid "Select internal destination"
msgstr "Vybrať interný cieľ"

#: fields.py:216
msgid "#anchor"
msgstr "#kotva"

#: fields.py:217
msgid "Provide an anchor to scroll to."
msgstr "Zadajte kotvu, ku ktorej sa má posunúť."

#: fields.py:227
msgid "Select a file as destination."
msgstr "Vyberte súbor ako cieľ."

#: fields.py:264
msgid "Select site"
msgstr "Vybrať lokalitu"

#: fields.py:313
msgid "Select a link type and provide a link."
msgstr "Vyberte typ odkazu a zadajte odkaz."

