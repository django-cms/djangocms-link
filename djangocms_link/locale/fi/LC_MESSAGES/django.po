#: admin.py:107
msgid "Page is not “last”, nor can it be converted to an int."
msgstr "Sivu ei ole “last”, eikä sitä voi muuntaa kokonaisluvuksi."

#: apps.py:10
msgid "django CMS Link"
msgstr "django CMS Linkki"

#: cms_plugins.py:43 models.py:73
msgid "Link"
msgstr "Linkki"

#: cms_plugins.py:66
msgid "Advanced settings"
msgstr "Lisäasetukset"

#: fields.py:154
msgid "Internal link"
msgstr "Sisäinen linkki"

#: fields.py:155
msgid "External link/anchor"
msgstr "Ulkoinen linkki/ankkuri"

#: fields.py:158
msgid "File link"
msgstr "Tiedostolinkki"

#: fields.py:190
msgid "No destination selected. Use the dropdown to select a destination."
msgstr "Kohdetta ei ole valittu. Valitse kohde pudotusvalikosta."

#: fields.py:197
msgid "https://example.com or #anchor"
msgstr "https://example.com tai #ankkuri"

#: fields.py:199
#, python-brace-format
msgid ""
"Provide a link to an external URL, including the schema such as {}. "
"Optionally, add an #anchor (including the #) to scroll to."
msgstr ""
"Anna linkki ulkoiseen URL-osoitteeseen ja sisällytä skeema, kuten {}. Voit "
"halutessasi lisätä #ankkurin (# mukaan lukien), johon vieritetään."

#: fields.py:208
msgid ""
"Select from available internal destinations. Optionally, add an anchor to "
"scroll to."
msgstr "Valitse käytettävissä olevista sisäisistä kohteista. Voit halutessasi lisätä ankkurin, johon vieritetään."

#: fields.py:210
msgid "Select internal destination"
msgstr "Valitse sisäinen kohde"

#: fields.py:216
msgid "#anchor"
msgstr "#ankkuri"

#: fields.py:217
msgid "Provide an anchor to scroll to."
msgstr "Anna ankkuri, johon vieritetään."

#: fields.py:227
msgid "Select a file as destination."
msgstr "Valitse tiedosto kohteeksi."

#: fields.py:264
msgid "Select site"
msgstr "Valitse sivusto"

#: fields.py:313
msgid "Select a link type and provide a link."
msgstr "Valitse linkkityyppi ja anna linkki."

#: models.py:28
msgid "Default"
