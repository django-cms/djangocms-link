msgstr "Išorinė nuoroda/inkaras"

#: fields.py:158
msgid "File link"
msgstr "Failo nuoroda"

#: fields.py:190
msgid "No destination selected. Use the dropdown to select a destination."
msgstr "Nepasirinkta paskirties vieta. Naudokite išskleidžiamąjį meniu paskirties vietai pasirinkti."

#: fields.py:197
msgid "https://example.com or #anchor"
msgstr "https://example.com arba #inkaras"

#: fields.py:199
#, python-brace-format
msgid ""
"Provide a link to an external URL, including the schema such as {}. "
"Optionally, add an #anchor (including the #) to scroll to."
msgstr "Pateikite nuorodą į išorinį URL, įskaitant schemą, pvz., {}. Pasirinktinai pridėkite #inkaras (įskaitant #), į kurį slinkti."

#: fields.py:208
msgid ""
"Select from available internal destinations. Optionally, add an anchor to "
"scroll to."
msgstr "Pasirinkite iš galimų vidinių paskirties vietų. Pasirinktinai pridėkite inkarą, į kurį slinkti."

#: fields.py:210
msgid "Select internal destination"
msgstr "Pasirinkti vidinę paskirties vietą"

#: fields.py:216
msgid "#anchor"
msgstr "#inkaras"

#: fields.py:217
msgid "Provide an anchor to scroll to."
msgstr "Pateikite inkarą, į kurį slinkti."

#: fields.py:227
msgid "Select a file as destination."
msgstr "Pasirinkite failą kaip paskirties vietą."

#: fields.py:264
msgid "Select site"
msgstr "Pasirinkti svetainę"

#: fields.py:313
msgid "Select a link type and provide a link."
msgstr "Pasirinkite nuorodos tipą ir pateikite nuorodą."

