msgid "Advanced settings"
msgstr "Configuración avanzada"

#: fields.py:154
msgid "Internal link"
msgstr "Enlace interno"

#: fields.py:155
msgid "External link/anchor"
msgstr "Enlace externo/ancla"

#: fields.py:158
msgid "File link"
msgstr "Enlace a archivo"

#: fields.py:190
msgid "No destination selected. Use the dropdown to select a destination."
msgstr "No se ha seleccionado ningún destino. Use el desplegable para seleccionar un destino."

#: fields.py:197
msgid "https://example.com or #anchor"
msgstr "https://example.com o #ancla"

#: fields.py:199
#, python-brace-format
msgid ""
"Provide a link to an external URL, including the schema such as {}. "
"Optionally, add an #anchor (including the #) to scroll to."
msgstr ""
"Proporcione un enlace a una URL externa, incluido el esquema como {}. "
"Opcionalmente, añada un #ancla (incluido el #) a la que desplazarse."

#: fields.py:208
msgid ""
"Select from available internal destinations. Optionally, add an anchor to "
"scroll to."
msgstr ""
"Seleccione entre los destinos internos disponibles. Opcionalmente, añada un "
"ancla a la que desplazarse."

#: fields.py:210
msgid "Select internal destination"
msgstr "Seleccionar destino interno"

#: fields.py:216
msgid "#anchor"
msgstr "#ancla"

#: fields.py:217
msgid "Provide an anchor to scroll to."
msgstr "Proporcione un ancla a la que desplazarse."

#: fields.py:227
msgid "Select a file as destination."
msgstr "Seleccione un archivo como destino."

#: fields.py:264
msgid "Select site"
msgstr "Seleccionar sitio"

#: fields.py:313
msgid "Select a link type and provide a link."
msgstr "Seleccione un tipo de enlace y proporcione un enlace."

