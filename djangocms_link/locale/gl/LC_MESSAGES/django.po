#: admin.py:107
msgid "Page is not “last”, nor can it be converted to an int."
msgstr "A páxina non é “last” nin se pode converter nun enteiro."

#: apps.py:10
msgid "django CMS Link"
msgstr "Ligazón de django CMS"

#: cms_plugins.py:43 models.py:73
msgid "Link"
msgstr "Ligazón"

#: cms_plugins.py:66
msgid "Advanced settings"
msgstr "Configuración avanzada"

#: fields.py:154
msgid "Internal link"
msgstr "Ligazón interna"

#: fields.py:155
msgid "External link/anchor"
msgstr "Ligazón externa/áncora"

#: fields.py:158
msgid "File link"
msgstr "Ligazón de ficheiro"

#: fields.py:190
msgid "No destination selected. Use the dropdown to select a destination."
msgstr "Non se seleccionou ningún destino. Use o despregable para seleccionar un destino."

#: fields.py:197
msgid "https://example.com or #anchor"
msgstr "https://example.com ou #ancora"

#: fields.py:199
#, python-brace-format
msgid ""
"Provide a link to an external URL, including the schema such as {}. "
"Optionally, add an #anchor (including the #) to scroll to."
msgstr "Proporcione unha ligazón a un URL externo, incluíndo o esquema como {}. Opcionalmente, engada unha #ancora (incluído o #) á que desprazarse."

#: fields.py:208
msgid ""
"Select from available internal destinations. Optionally, add an anchor to "
"scroll to."
msgstr "Seleccione entre os destinos internos dispoñibles. Opcionalmente, engada unha áncora á que desprazarse."

#: fields.py:210
msgid "Select internal destination"
msgstr "Seleccionar destino interno"

#: fields.py:216
msgid "#anchor"
msgstr "#ancora"

#: fields.py:217
msgid "Provide an anchor to scroll to."
msgstr "Proporcione unha áncora á que desprazarse."

#: fields.py:227
msgid "Select a file as destination."
msgstr "Seleccione un ficheiro como destino."

#: fields.py:264
msgid "Select site"
msgstr "Seleccionar sitio"

#: fields.py:313
msgid "Select a link type and provide a link."
msgstr "Seleccione un tipo de ligazón e proporcione unha ligazón."

#: models.py:28
msgid "Default"
msgstr "Predeterminado"

#: models.py:41
msgid "Open in new window"
msgstr "Abrir nunha nova xanela"

#: models.py:42
msgid "Open in same window"
msgstr "Abrir na mesma xanela"

#: models.py:43
msgid "Delegate to parent"
msgstr "Delegar no pai"

#: models.py:44
msgid "Delegate to top"
msgstr "Delegar no superior"

#: models.py:61
msgid "Template"
msgstr "Modelo"

#: models.py:67
msgid "Display name"
msgstr "Nome para mostrar"

#: models.py:77
msgid "Target"
msgstr "Destino"

#: models.py:103
msgid "Attributes"
msgstr "Atributos"

#: models.py:130
msgid "<link is missing>"
msgstr "<falta a ligazón>"

#: models.py:139
msgid "Link is required."
msgstr "A ligazón é obrigatoria."

#: validators.py:61
msgid "Enter a valid anchor"
msgstr "Introduza unha áncora válida"

#: validators.py:104
msgid "Enter a valid phone number"
msgstr "Introduza un número de teléfono válido"
