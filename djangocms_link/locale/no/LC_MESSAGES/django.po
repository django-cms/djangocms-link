msgstr "Ekstern lenke/anker"

#: fields.py:158
msgid "File link"
msgstr "Fillenke"

#: fields.py:190
msgid "No destination selected. Use the dropdown to select a destination."
msgstr "Ingen destinasjon valgt. Bruk nedtrekksmenyen for å velge en destinasjon."

#: fields.py:197
msgid "https://example.com or #anchor"
msgstr "https://example.com eller #anker"

#: fields.py:199
#, python-brace-format
msgid ""
"Provide a link to an external URL, including the schema such as {}. "
"Optionally, add an #anchor (including the #) to scroll to."
msgstr "Oppgi en lenke til en ekstern URL, inkludert skjema som {}. Legg eventuelt til et #anker (inkludert #) å rulle til."

#: fields.py:208
msgid ""
"Select from available internal destinations. Optionally, add an anchor to "
"scroll to."
msgstr "Velg blant tilgjengelige interne destinasjoner. Legg eventuelt til et anker å rulle til."

#: fields.py:210
msgid "Select internal destination"
msgstr "Velg intern destinasjon"

#: fields.py:216
msgid "#anchor"
msgstr "#anker"

#: fields.py:217
msgid "Provide an anchor to scroll to."
msgstr "Oppgi et anker å rulle til."

#: fields.py:227
msgid "Select a file as destination."
msgstr "Velg en fil som destinasjon."

#: fields.py:264
msgid "Select site"
msgstr "Velg nettsted"

#: fields.py:313
msgid "Select a link type and provide a link."
msgstr "Velg en lenketype og oppgi en lenke."

