msgid "Link"
msgstr "Lenke"

#: cms_plugins.py:66
msgid "Advanced settings"
msgstr "Avanserte innstillinger"

#: fields.py:154
msgid "Internal link"
msgstr "Intern lenke"

#: fields.py:155
