#: admin.py:107
msgid "Page is not “last”, nor can it be converted to an int."
msgstr "Bladsy is nie “last” nie, en kan ook nie na ’n heelgetal omgeskakel word nie."

#: apps.py:10
msgid "django CMS Link"
msgstr "django CMS-skakel"

#: cms_plugins.py:43 models.py:73
msgid "Link"
msgstr "Skakel"

#: cms_plugins.py:66
msgid "Advanced settings"
msgstr "Gevorderde instellings"

#: fields.py:154
msgid "Internal link"
msgstr "Interne skakel"

#: fields.py:155
msgid "External link/anchor"
msgstr "Eksterne skakel/anker"

#: fields.py:158
msgid "File link"
msgstr "Lêerskakel"

#: fields.py:190
msgid "No destination selected. Use the dropdown to select a destination."
msgstr "Geen bestemming gekies nie. Gebruik die aftreklys om ’n bestemming te kies."

#: fields.py:197
msgid "https://example.com or #anchor"
msgstr "https://example.com of #anker"

#: fields.py:199
#, python-brace-format
msgid ""
"Provide a link to an external URL, including the schema such as {}. "
"Optionally, add an #anchor (including the #) to scroll to."
msgstr "Verskaf ’n skakel na ’n eksterne URL, insluitend die skema soos {}. Voeg opsioneel ’n #anker (insluitend die #) by om na te rol."

#: fields.py:208
msgid ""
"Select from available internal destinations. Optionally, add an anchor to "
"scroll to."
msgstr "Kies uit beskikbare interne bestemmings. Voeg opsioneel ’n anker by om na te rol."

#: fields.py:210
msgid "Select internal destination"
msgstr "Kies interne bestemming"

#: fields.py:216
msgid "#anchor"
msgstr "#anker"

#: fields.py:217
msgid "Provide an anchor to scroll to."
msgstr "Verskaf ’n anker om na te rol."

#: fields.py:227
msgid "Select a file as destination."
msgstr "Kies ’n lêer as bestemming."

#: fields.py:264
msgid "Select site"
msgstr "Kies werf"

#: fields.py:313
msgid "Select a link type and provide a link."
msgstr "Kies ’n skakeltipe en verskaf ’n skakel."

#: models.py:28
msgid "Default"
msgstr "Verstek"

