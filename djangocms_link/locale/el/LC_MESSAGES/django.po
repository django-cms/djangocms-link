msgid "Page is not “last”, nor can it be converted to an int."
msgstr "Η σελίδα δεν είναι “last” ούτε μπορεί να μετατραπεί σε ακέραιο."

#: apps.py:10
msgid "django CMS Link"
msgstr "Σύνδεσμος django CMS"

#: cms_plugins.py:43 models.py:73
msgid "Link"
msgstr "Σύνδεσμος"

#: cms_plugins.py:66
msgid "Advanced settings"
msgstr "Σύνθετες ρυθμίσεις"

#: fields.py:154
msgid "Internal link"
msgstr "Εσωτερικός σύνδεσμος"

#: fields.py:155
msgid "External link/anchor"
