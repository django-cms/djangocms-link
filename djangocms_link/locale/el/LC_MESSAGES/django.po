#: fields.py:158
msgid "File link"
msgstr "Σύνδεσμος αρχείου"

#: fields.py:190
msgid "No destination selected. Use the dropdown to select a destination."
msgstr "Δεν έχει επιλεγεί προορισμός. Χρησιμοποιήστε το αναπτυσσόμενο μενού για να επιλέξετε προορισμό."

#: fields.py:197
msgid "https://example.com or #anchor"
msgstr "https://example.com ή #anchor"

#: fields.py:199
#, python-brace-format
msgid ""
"Provide a link to an external URL, including the schema such as {}. "
"Optionally, add an #anchor (including the #) to scroll to."
msgstr "Δώστε έναν σύνδεσμο προς εξωτερικό URL, συμπεριλαμβάνοντας το σχήμα όπως {}. Προαιρετικά, προσθέστε ένα #anchor (μαζί με το #) για κύλιση σε αυτό."

#: fields.py:208
msgid ""
"Select from available internal destinations. Optionally, add an anchor to "
"scroll to."
msgstr "Επιλέξτε από τους διαθέσιμους εσωτερικούς προορισμούς. Προαιρετικά, προσθέστε μια άγκυρα για κύλιση σε αυτή."

#: fields.py:210
msgid "Select internal destination"
msgstr "Επιλέξτε εσωτερικό προορισμό"

#: fields.py:216
msgid "#anchor"
msgstr "#anchor"

#: fields.py:217
msgid "Provide an anchor to scroll to."
msgstr "Δώστε μια άγκυρα για κύλιση σε αυτή."

#: fields.py:227
msgid "Select a file as destination."
msgstr "Επιλέξτε ένα αρχείο ως προορισμό."

#: fields.py:264
msgid "Select site"
msgstr "Επιλέξτε ιστότοπο"

#: fields.py:313
msgid "Select a link type and provide a link."
msgstr "Επιλέξτε τύπο συνδέσμου και δώστε έναν σύνδεσμο."

