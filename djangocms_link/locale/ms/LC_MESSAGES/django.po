msgid "django CMS Link"
msgstr "Pautan django CMS"

#: cms_plugins.py:43 models.py:73
msgid "Link"
msgstr "Pautan"

#: cms_plugins.py:66
msgid "Advanced settings"
msgstr "Tetapan lanjutan"

#: fields.py:154
msgid "Internal link"
msgstr "Pautan dalaman"

#: fields.py:155
msgid "External link/anchor"
msgstr "Pautan luaran/penambat"

#: fields.py:158
msgid "File link"
msgstr "Pautan fail"

#: fields.py:190
msgid "No destination selected. Use the dropdown to select a destination."
msgstr "Tiada destinasi dipilih. Gunakan menu lungsur untuk memilih destinasi."

#: fields.py:197
msgid "https://example.com or #anchor"
msgstr "https://example.com atau #anchor"

#: fields.py:199
#, python-brace-format
msgid ""
"Provide a link to an external URL, including the schema such as {}. "
"Optionally, add an #anchor (including the #) to scroll to."
msgstr "Berikan pautan ke URL luaran, termasuk skema seperti {}. Secara pilihan, tambah #anchor (termasuk #) untuk ditatal ke situ."

#: fields.py:208
msgid ""
"Select from available internal destinations. Optionally, add an anchor to "
"scroll to."
msgstr "Pilih daripada destinasi dalaman yang tersedia. Secara pilihan, tambah penambat untuk ditatal ke situ."

#: fields.py:210
msgid "Select internal destination"
msgstr "Pilih destinasi dalaman"

#: fields.py:216
msgid "#anchor"
msgstr "#anchor"

#: fields.py:217
msgid "Provide an anchor to scroll to."
msgstr "Berikan penambat untuk ditatal ke situ."

#: fields.py:227
msgid "Select a file as destination."
msgstr "Pilih fail sebagai destinasi."

#: fields.py:264
msgid "Select site"
msgstr "Pilih laman"

#: fields.py:313
msgid "Select a link type and provide a link."
msgstr "Pilih jenis pautan dan berikan pautan."

#: models.py:28
msgid "Default"
msgstr "Lalai"

