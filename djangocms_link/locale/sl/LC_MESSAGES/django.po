#: fields.py:199
#, python-brace-format
msgid ""
"Provide a link to an external URL, including the schema such as {}. "
"Optionally, add an #anchor (including the #) to scroll to."
msgstr "Vnesite povezavo do zunanjega URL-ja, vključno s shemo, kot je {}. Po želji dodajte #sidro (vključno z #), do katerega se pomakne."

#: fields.py:208
msgid ""
"Select from available internal destinations. Optionally, add an anchor to "
"scroll to."
msgstr "Izberite med razpoložljivimi notranjimi cilji. Po želji dodajte sidro, do katerega se pomakne."

